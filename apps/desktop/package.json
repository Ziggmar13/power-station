{
    "name":  "power-station-desktop",
    "version":  "1.0.0",
    "private":  true,
    "description":  "Power Station desktop agent — sends WoL packets and shutdown commands",
    "main":  "out/main/index.js",
    "scripts":  {
                    "dev":  "tsc -p tsconfig.json \u0026\u0026 electron out/main/index.js",
                    "build":  "tsc -p tsconfig.json",
                    "dist":  "pnpm build \u0026\u0026 electron-builder build --win --config electron-builder.config.js",
                    "dist:portable":  "pnpm build \u0026\u0026 electron-builder build --win portable --config electron-builder.config.js",
                    "type-check":  "tsc --noEmit"
                },
    "dependencies":  {
                         "@supabase/supabase-js":  "^2.103.0",
                         "auto-launch":  "^5.0.6",
                         "dotenv":  "^16.5.0",
                         "electron-log":  "^5.3.5",
                         "wake_on_lan":  "^1.0.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^20.19.39",
                            "electron":  "^36.3.1",
                            "electron-builder":  "^25.1.8",
                            "typescript":  "^5.8.3"
                        }
}
