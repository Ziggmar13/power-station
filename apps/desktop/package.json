{
  "name": "desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Power Station desktop agent — sends WoL packets and shutdown commands",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron dist/main/index.js",
    "build": "tsc -p tsconfig.json",
    "dist": "pnpm build && electron-builder build --win",
    "dist:portable": "pnpm build && electron-builder build --win portable",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "auto-launch": "^5.0.6",
    "dotenv": "^16.5.0",
    "electron-log": "^5.3.5",
    "wake_on_lan": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3"
  }
}
