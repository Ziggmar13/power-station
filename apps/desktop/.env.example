# Supabase — get these from your Supabase project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...    # use the service_role key (not anon)

# The UUID of this computer from the Power Station dashboard
# After adding your computer in the web app, copy the ID from Supabase → Table Editor → computers
COMPUTER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your web app URL (Vercel deployment or localhost for dev)
APP_URL=https://your-app.vercel.app
